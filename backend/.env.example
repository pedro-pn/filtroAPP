PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/filtrovali?schema=public"
ASSETS_DIR="./assets"
REPORTS_DIR="./Relatórios"

# URL base do sistema (usado nos links de e-mail)
# Exemplo local: http://localhost:5173
# Exemplo produção: https://relatorios.suaempresa.com.br
APP_URL="http://localhost:5173"
# Obrigatório em produção. Use "false" somente se o backend não estiver atrás de proxy.
# Em Docker com Nginx na rede interna, prefira "uniquelocal" ou CIDRs explícitos.
TRUST_PROXY=false
SURVEY_TOKEN_SECRET="troque-por-um-segredo-longo-e-estavel"
# Obrigatório em produção para links de assinatura de RDO.
# Em upgrade de uma instalação existente, configure SIGNATURE_TOKEN_SECRET_PREVIOUS
# com o segredo antigo usado pelos tokens já emitidos.
SIGNATURE_TOKEN_SECRET="troque-por-outro-segredo-longo-e-estavel"
SIGNATURE_TOKEN_SECRET_PREVIOUS=""

# Configurações SMTP — Microsoft Exchange
# Exchange Online (M365): SMTP_HOST=smtp.office365.com  SMTP_PORT=587
# Exchange on-premises:   SMTP_HOST=<endereço do servidor interno>  SMTP_PORT=587
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="email_da_empresa@suaempresa.com.br"
SMTP_PASS="senha_ou_app_password"
SMTP_FROM="Filtrovali <email_da_empresa@suaempresa.com.br>"

# Defina false em homologação/testes com banco de produção para bloquear envios operacionais do sistema.
# O script scripts/test-email.js continua podendo enviar somente para SMTP_TEST_DEST.
SEND_CLIENT_EMAILS=true

# E-mail de destino apenas para o script de teste (scripts/test-email.js)
SMTP_TEST_DEST="seu_email@example.com"

# Token de serviço para o envio do banco comercial Access (propostas_bd.accdb) via API.
# Usado pelo script periódico do comercial (POST /api/acompanhamento/comercial/import).
# Gere um valor longo e aleatório (ex.: openssl rand -hex 32). Vazio = endpoint desabilitado.
COMMERCIAL_IMPORT_TOKEN=""

# Integração Omie (compras por projeto). App Key/Secret da aplicação Omie.
# Usados pelo script de descoberta (npm run omie:explore) e, futuramente, pela sincronização.
OMIE_APP_KEY=""
OMIE_APP_SECRET=""
