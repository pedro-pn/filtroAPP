generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportType {
  RDO
  RTP
  RLQ
  RCPU
  RLM
  RLF
  RLI
}

enum ReportStatus {
  PENDING
  APPROVED
  RETURNED
  SIGNED
}

enum ClientReviewAction {
  APPROVED
  REJECTED
}

enum ReportVersionStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  REJECTED
}

enum ReportSignerRole {
  COLLABORATOR
  MANAGER
  CLIENT
}

enum ReportSignatureType {
  ELECTRONIC
  DIGITAL_A1
}

enum ReportSignatureStatus {
  PENDING
  SIGNED
  REJECTED
  INVALIDATED
  EXPIRED
}

enum ReportAuditAction {
  SIGNATURE_ROUND_CREATED
  SIGNED
  REJECTED
  SIGNATURES_INVALIDATED
  VERSION_CREATED
  TOKEN_ACCESSED
  TOKEN_EXPIRED
  REPORT_LOCKED
}

enum UserRole {
  COLLABORATOR
  MANAGER
  COORDINATOR
  CLIENT
}

enum AccountType {
  ADMIN
  INTERNAL
  CLIENT
}

enum AppModule {
  RDO
  ROMANEIO
  EPI
  PRIVACY
  EQUIPAMENTOS
}

enum ModuleRoleCode {
  RDO_MANAGER
  RDO_COORDINATOR
  RDO_COLLABORATOR
  RDO_CLIENT
  ROMANEIO_MANAGER
  ROMANEIO_OPERATOR
  EPI_TECHNICIAN
  EPI_COLLABORATOR
  PRIVACY_ADMIN
  EQUIPAMENTOS_MANAGER
  EQUIPAMENTOS_VIEWER
}

enum RomaneioItemKind {
  EQUIPMENT
  CONNECTION
}

enum RomaneioMeasureType {
  UNIT
  LENGTH
  WEIGHT
}

enum RomaneioCatalogSource {
  FILE
  MANUAL
  UNIT
  PARTICLE_COUNTER
  EQUIPAMENTOS
}

enum DataSubjectRequestType {
  CONFIRMATION
  ACCESS
  CORRECTION
  ANONYMIZATION
  BLOCKING
  DELETION
  PORTABILITY
  SHARING_INFO
  CONSENT_REVOCATION
  OPPOSITION
  OTHER
}

enum DataSubjectRequestStatus {
  OPEN
  IN_REVIEW
  COMPLETED
  REJECTED
  CANCELLED
}

model Collaborator {
  id               String    @id @default(cuid())
  code             String    @unique
  name             String
  role             String
  email            String?
  cpf              String?
  registrationNumber String?
  admissionDate    DateTime?
  signatureImage   String?
  signatureNoticeAcceptedAt DateTime?
  signatureNoticeVersion String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  projectsLed      Project[] @relation("ProjectOperator")
  reportLinks      ReportCollaborator[]
  user             User?
  epiRecords       EpiRecord[]
  epiSignatureRequests EpiSignatureRequest[]
  signatureNoticeLogs CollaboratorSignatureNoticeLog[]
}

model CollaboratorSignatureNoticeLog {
  id             String       @id @default(cuid())
  collaboratorId String
  userId         String?
  noticeVersion  String
  createdAt      DateTime     @default(now())
  collaborator   Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  user           User?        @relation("CollaboratorSignatureNoticeUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([collaboratorId])
  @@index([userId])
  @@index([createdAt])
}

model ClientSegment {
  id        String   @id @default(cuid())
  label     String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                    String            @id @default(cuid())
  code                  String            @unique
  name                  String
  isActive              Boolean           @default(true)
  visibleToCollaborators Boolean          @default(true)
  managerOnly           Boolean           @default(false)
  registrationPending   Boolean           @default(false)
  inhibitionServiceEnabled Boolean        @default(false)
  clientName            String
  clientCnpj            String
  clientEmailPrimary    String            @default("")
  clientEmailCc         String[]          @default([])
  clientSigners         Json[]            @default([])
  contractCode          String
  location              String
  workdayHours          String            @default("09:00")
  weekendWorkdayHours   String            @default("08:00")
  includesSaturday      Boolean           @default(false)
  includesSunday        Boolean           @default(false)
  operatorId            String?
  clientSegment         String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?
  operator              Collaborator?     @relation("ProjectOperator", fields: [operatorId], references: [id], onDelete: SetNull)
  reportSequences       ProjectReportSeq[]
  authorizedUsers       ProjectAuthorizedUser[]
  reports               Report[]
  drafts                ReportDraft[]
  surveys               SatisfactionSurvey[]
  romaneios             Romaneio[]

  @@index([deletedAt])
  @@index([registrationPending])
}

model ProjectReportSeq {
  id         String     @id @default(cuid())
  projectId  String
  reportType ReportType
  nextNumber Int        @default(0)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, reportType])
}

model ProjectAuthorizedUser {
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}

model Report {
  id              String               @id @default(cuid())
  projectId       String
  createdByUserId String?
  reviewedByUserId String?
  reportType      ReportType           @default(RDO)
  sequenceNumber  Int?
  status          ReportStatus         @default(PENDING)
  reportDate      DateTime
  arrivalTime     String
  departureTime   String
  lunchBreak      String
  daytimeCount    Int
  daytimeWorkedMinutes Int            @default(0)
  nighttimeWorkedMinutes Int          @default(0)
  daytimeOvertimeMinutes Int          @default(0)
  nighttimeOvertimeMinutes Int        @default(0)
  totalOvertimeMinutes Int            @default(0)
  overtimeReason  String?
  dailyDescription String?
  reviewNotes     String?
  specialConditions Json?
  pendingDerivedTypes Json?
  approvedAt      DateTime?
  returnedAt      DateTime?
  zapsignDocToken String?
  zapsignSignerToken String?
  zapsignRequestedAt DateTime?
  zapsignSignedAt DateTime?
  zapsignDocUrl   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Restrict)
  createdBy       User?                @relation("ReportCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedBy      User?                @relation("ReportReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  collaborators   ReportCollaborator[]
  services        ReportService[]
  attachments     ReportAttachment[]
  clientReviews   ClientReportReview[]
  versions        ReportVersion[]
  reportSignatures ReportSignature[]
  auditLogs       ReportAuditLog[]

  @@unique([projectId, reportType, sequenceNumber])
  @@index([projectId])
  @@index([createdByUserId])
  @@index([status])
  @@index([projectId, status])
  @@index([projectId, reportType])
  @@index([reportDate])
  @@index([zapsignDocToken])
  @@index([reportType, status, reportDate])
  @@index([projectId, reportType, status, reportDate])
  @@index([deletedAt])
}

model ClientReportReview {
  id           String             @id @default(cuid())
  reportId     String
  clientUserId String?
  action       ClientReviewAction
  comment      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime           @default(now())
  report       Report             @relation(fields: [reportId], references: [id], onDelete: Cascade)
  clientUser   User?              @relation("ClientReportReviewer", fields: [clientUserId], references: [id], onDelete: SetNull)

  @@index([reportId, createdAt])
}

model ReportVersion {
  id                 String              @id @default(cuid())
  reportId           String
  versionNumber      Int
  sourcePdfUrl       String
  finalPdfUrl        String?
  sourceDocumentHash String
  finalDocumentHash  String?
  validationCode     String?             @unique
  status             ReportVersionStatus @default(ACTIVE)
  createdByUserId    String?
  createdAt          DateTime            @default(now())
  report             Report              @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdBy          User?               @relation("ReportVersionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  signatures         ReportSignature[]
  auditLogs          ReportAuditLog[]

  @@unique([reportId, versionNumber])
  @@index([reportId])
  @@index([reportId, status])
}

model ReportSignature {
  id                 String                @id @default(cuid())
  reportId           String
  versionId          String
  userId             String?
  signerName         String
  declaredSignerName String?
  signerEmail        String
  signerRole         ReportSignerRole
  signatureType      ReportSignatureType   @default(ELECTRONIC)
  status             ReportSignatureStatus @default(PENDING)
  isRequired         Boolean               @default(true)
  ipAddress          String?
  userAgent          String?
  signatureImageDataUrl String?
  privacyNoticeAcceptedAt DateTime?
  privacyNoticeVersion String?
  sourceDocumentHash String
  finalDocumentHash  String?
  signedAt           DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  invalidatedAt      DateTime?
  tokenHash          String?               @unique
  tokenEncrypted     String?
  tokenIv            String?
  tokenAuthTag       String?
  tokenExpiresAt     DateTime?
  lastReminderAt     DateTime?
  reminderClaimedAt  DateTime?
  reminderCount      Int                   @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  report             Report                @relation(fields: [reportId], references: [id], onDelete: Cascade)
  version            ReportVersion         @relation(fields: [versionId], references: [id], onDelete: Cascade)
  user               User?                 @relation("ReportSignatureUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([versionId, signerEmail])
  @@index([reportId])
  @@index([versionId])
  @@index([status])
  @@index([status, lastReminderAt, reminderClaimedAt])
}

model ReportAuditLog {
  id        String            @id @default(cuid())
  reportId  String
  versionId String?
  userId    String?
  action    ReportAuditAction
  description String?
  ipAddress String?
  userAgent String?
  createdAt DateTime          @default(now())
  report    Report            @relation(fields: [reportId], references: [id], onDelete: Cascade)
  version   ReportVersion?    @relation(fields: [versionId], references: [id], onDelete: SetNull)
  user      User?             @relation("ReportAuditLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([reportId])
  @@index([versionId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ReportCollaborator {
  reportId       String
  collaboratorId String
  report         Report        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  collaborator   Collaborator  @relation(fields: [collaboratorId], references: [id], onDelete: Restrict)

  @@id([reportId, collaboratorId])
}

model ReportService {
  id            String   @id @default(cuid())
  reportId      String
  serviceType   String
  equipmentId   String?
  system        String?
  material      String?
  startTime     String?
  endTime       String?
  finalized     Boolean?
  extraData     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  report        Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  equipment     Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  attachments   ReportAttachment[]

  @@index([reportId])
}

model Equipment {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  serviceTags String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reportServices ReportService[]
}

model InhibitionVessel {
  id        String   @id @default(cuid())
  code      String   @unique
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InhibitionSystem {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  diagram     String
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Unit {
  id         String       @id @default(cuid())
  code       String       @unique
  name       String
  category   String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Manometer {
  id                  String   @id @default(cuid())
  code                String   @unique
  scale               String
  calibrationCertCode String
  calibratedAt        DateTime
  expiresAt           DateTime
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  calibrationCertificates CalibrationCertificate[]
}

model ParticleCounter {
  id           String   @id @default(cuid())
  code         String   @unique
  serialNumber String
  category     String   @default("CONTADOR DE PARTICULAS")
  calibratedAt DateTime
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  calibrationCertificates CalibrationCertificate[]

  @@index([category])
}

enum CalibrationEquipmentType {
  MANOMETER
  PARTICLE_COUNTER
}

model CalibrationCertificate {
  id                String                   @id @default(cuid())
  equipmentType     CalibrationEquipmentType
  fileName          String
  mimeType          String                   @default("application/pdf")
  storagePath       String
  publicToken       String                   @unique
  manometerId       String?
  particleCounterId String?
  manometer         Manometer?               @relation(fields: [manometerId], references: [id], onDelete: Cascade)
  particleCounter   ParticleCounter?         @relation(fields: [particleCounterId], references: [id], onDelete: Cascade)
  createdAt         DateTime                 @default(now())

  @@index([manometerId, createdAt])
  @@index([particleCounterId, createdAt])
}

model CalibrationNotificationLog {
  id            String   @id @default(cuid())
  equipmentType String
  equipmentId   String
  category      String
  milestone     String
  targetDate    DateTime
  sentAt        DateTime @default(now())

  @@unique([equipmentType, equipmentId, milestone, targetDate])
  @@index([category, milestone, sentAt])
}

// === Módulo Equipamentos ===

model EquipmentCategory {
  id                   String             @id @default(cuid())
  systemKey            String             @unique // slug imutável usado pelo RDO/romaneio
  name                 String // rótulo editável (vira a aba)
  order                Int                @default(0)
  fieldSchema          Json               @default("[]") // [{ key, label, type, required, options?, order, showInDashboard? }]
  technicalSchema      Json               @default("[]") // dados técnicos: [{ key, label, type, group?, unit?, options?, repeatable?, itemSchema?, optionalPerEquipment?, showInDoc?, order }]
  technicalDocEnabled  Boolean            @default(false) // liga a aba "Dados Técnicos" (datasheet estruturado + geração DOCX→PDF)
  technicalTemplateId  String? // DOCX modelo da categoria (Etapa F); null = usa o modelo genérico
  supportsCalibration  Boolean            @default(false)
  supportsTechnicalDoc Boolean            @default(true) // anexo PDF legado (mantido como histórico)
  syncToRomaneio       Boolean            @default(false)
  isSystemManaged      Boolean            @default(false) // categorias consumidas pelo RDO (não removíveis)
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  equipment            CompanyEquipment[]
}

model CompanyEquipment {
  id              String                @id @default(cuid())
  code            String                @unique
  name            String
  categoryId      String
  attributes      Json                  @default("{}") // valores dos campos dinâmicos, keyed por field.key
  technicalData   Json                  @default("{}") // valores do datasheet, keyed por technicalSchema.key
  technicalFieldOverrides Json          @default("{}") // inclusão/exclusão de campos optionalPerEquipment, keyed por key -> bool
  technicalRevision Int                 @default(0)
  technicalUpdatedAt DateTime?
  hasCalibration  Boolean               @default(false)
  calibratedAt    DateTime?
  expiresAt       DateTime?
  hasTechnicalDoc Boolean               @default(false)
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  category        EquipmentCategory     @relation(fields: [categoryId], references: [id])
  attachments     EquipmentAttachment[]

  @@index([categoryId])
  @@index([expiresAt])
}

enum EquipmentAttachmentKind {
  CALIBRATION_CERTIFICATE
  TECHNICAL_DOC
  TECHNICAL_TEMPLATE
  TECHNICAL_DOC_GENERATED
}

// Destinatários das notificações de calibração do módulo Equipamentos: contas
// internas (userId) ou e-mails avulsos. Substitui a lista fixa de gestores/coordenadores.
model EquipmentNotificationRecipient {
  id        String   @id @default(cuid())
  userId    String?
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Configuração (singleton) dos e-mails de calibração: marcos, repetição e on/off.
model EquipmentNotificationConfig {
  id             String   @id @default(cuid())
  enabled        Boolean  @default(true)
  milestoneDays  Int[]    @default([30, 15, 7])
  notifyOnDueDay Boolean  @default(true)
  repeatExpired  Boolean  @default(true)
  repeatGapDays  Int      @default(5)
  updatedAt      DateTime @updatedAt
}

// Mapeamento configurável: cada "slot" de equipamento do formulário de RDO
// (definido no catálogo de código) aponta para uma categoria de equipamento.
model RdoEquipmentSlot {
  id         String   @id @default(cuid())
  slotKey    String   @unique
  categoryId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId])
}

model EquipmentAttachment {
  id          String                  @id @default(cuid())
  equipmentId String
  kind        EquipmentAttachmentKind
  fileName    String
  mimeType    String                  @default("application/pdf")
  storagePath String
  publicToken String                  @unique
  createdAt   DateTime                @default(now())
  equipment   CompanyEquipment        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, kind, createdAt])
}

model User {
  id              String        @id @default(cuid())
  username        String        @unique
  name            String
  email           String?
  emailVerifiedAt DateTime?
  passwordHash    String
  role            UserRole
  accountType     AccountType   @default(INTERNAL)
  isActive        Boolean       @default(true)
  clientCnpj      String?
  privacyPolicyAcceptedAt DateTime?
  privacyPolicyVersion String?
  notifyReportsByEmail Boolean @default(true)
  notifySignaturesByEmail Boolean @default(true)
  notifySignatureRemindersByEmail Boolean @default(true)
  notifySurveyRemindersByEmail Boolean @default(true)
  notifyCalibrationRemindersByEmail Boolean @default(true)
  collaboratorId  String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  collaborator    Collaborator? @relation(fields: [collaboratorId], references: [id], onDelete: SetNull)
  moduleRoles     ModuleRole[]
  sessions        UserSession[]
  passwordResetTokens PasswordResetToken[]
  emailChangeTokens EmailChangeToken[]
  drafts          ReportDraft[]
  authorizedProjects ProjectAuthorizedUser[]
  createdReports  Report[]      @relation("ReportCreator")
  reviewedReports Report[]      @relation("ReportReviewer")
  clientReportReviews ClientReportReview[] @relation("ClientReportReviewer")
  reportVersions  ReportVersion[] @relation("ReportVersionCreator")
  reportSignatures ReportSignature[] @relation("ReportSignatureUser")
  reportAuditLogs ReportAuditLog[] @relation("ReportAuditLogUser")
  collaboratorSignatureNoticeLogs CollaboratorSignatureNoticeLog[] @relation("CollaboratorSignatureNoticeUser")
  sentSurveys     SatisfactionSurvey[]
  createdRomaneios Romaneio[] @relation("RomaneioCreator")
  createdEpiRecords EpiRecord[] @relation("EpiRecordCreator")
  epiSignatureRequests EpiSignatureRequest[] @relation("EpiSignatureRequester")
  dataSubjectRequests DataSubjectRequest[] @relation("DataSubjectRequestUser")
  completedDataSubjectRequests DataSubjectRequest[] @relation("DataSubjectRequestCompletedByUser")
  identityVerifiedDataSubjectRequests DataSubjectRequest[] @relation("DataSubjectRequestIdentityVerifiedByUser")
  dataSubjectResponseAttempts DataSubjectRequestResponseAttempt[] @relation("DataSubjectRequestResponseAttemptUser")
  notificationPreferenceTokens NotificationPreferenceToken[]

  @@index([clientCnpj])
}

model NotificationPreferenceToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
  @@index([expiresAt])
}

model EpiCatalogItem {
  id        String   @id @default(cuid())
  name      String
  ca        String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  records   EpiRecord[]

  @@unique([name, ca])
  @@index([isActive])
  @@index([name])
}

model EpiRecord {
  id                 String   @id @default(cuid())
  collaboratorId     String
  catalogItemId      String?
  epiName            String
  ca                 String
  quantity           Int      @default(1)
  lendDate           DateTime
  devolutionDate     DateTime?
  signatureRequestId String?
  signatureImageDataUrl String?
  signatureSignerName String?
  signedAt           DateTime?
  pendingReturn      Boolean  @default(false)
  returnSourceRecordId String?
  archivedAt         DateTime?
  createdByUserId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  collaborator       Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Restrict)
  catalogItem        EpiCatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  signatureRequest   EpiSignatureRequest? @relation(fields: [signatureRequestId], references: [id], onDelete: SetNull)
  createdBy          User? @relation("EpiRecordCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([collaboratorId])
  @@index([catalogItemId])
  @@index([signatureRequestId])
  @@index([signedAt])
  @@index([pendingReturn])
  @@index([returnSourceRecordId])
  @@index([archivedAt])
  @@index([collaboratorId, lendDate, createdAt])
}

model EpiSignatureRequest {
  id                String   @id @default(cuid())
  collaboratorId    String
  requestedByUserId String?
  tokenHash         String   @unique
  status            String   @default("PENDING")
  expiresAt         DateTime
  signedAt          DateTime?
  signatureImageDataUrl String?
  signatureSignerName String?
  signedPdfPath     String?
  signedPdfHash     String?
  signedPdfFileName String?
  ipAddress         String?
  userAgent         String?
  privacyNoticeAcceptedAt DateTime?
  privacyNoticeVersion String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  collaborator      Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Restrict)
  requestedBy       User? @relation("EpiSignatureRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  records           EpiRecord[]
  auditLogs         EpiSignatureRequestAuditLog[]

  @@index([collaboratorId])
  @@index([status])
  @@index([expiresAt])
}

model EpiSignatureRequestAuditLog {
  id        String   @id @default(cuid())
  requestId String
  action    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  request   EpiSignatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([action])
  @@index([createdAt])
}

model Romaneio {
  id              String         @id @default(cuid())
  projectId       String
  createdByUserId String?
  romaneioDate    DateTime
  driverName      String
  vehiclePlate    String
  cargoWeight     Decimal?       @db.Decimal(12, 3)
  cargoWeightUnit String?
  docxUrl         String?
  pdfUrl          String?
  emailStatus     String?
  emailError      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  createdBy       User?          @relation("RomaneioCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items           RomaneioItem[]

  @@index([projectId])
  @@index([createdByUserId])
  @@index([romaneioDate])
  @@index([createdAt])
  @@index([projectId, romaneioDate, createdAt])
}

model RomaneioItem {
  id            String               @id @default(cuid())
  romaneioId    String
  catalogItemId String?
  itemName      String
  itemCode      String?
  categoryName  String
  kind          RomaneioItemKind     @default(EQUIPMENT)
  measureType   RomaneioMeasureType  @default(UNIT)
  quantity      Decimal              @db.Decimal(12, 3)
  unitLabel     String
  isCustom      Boolean              @default(false)
  sortOrder     Int                  @default(0)
  romaneio      Romaneio             @relation(fields: [romaneioId], references: [id], onDelete: Cascade)
  catalogItem   RomaneioCatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@index([romaneioId])
  @@index([catalogItemId])
}

model RomaneioCatalogItem {
  id             String                  @id @default(cuid())
  sourceType     RomaneioCatalogSource   @default(MANUAL)
  sourceId       String?
  code           String?
  name           String
  categoryName   String
  kind           RomaneioItemKind        @default(EQUIPMENT)
  measureType    RomaneioMeasureType     @default(UNIT)
  defaultUnitLabel String                 @default("unidade")
  isSerialized   Boolean                 @default(true)
  isActive       Boolean                 @default(true)
  hiddenInRomaneioAt DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  romaneioItems  RomaneioItem[]

  @@unique([sourceType, sourceId])
  @@unique([categoryName, code, name])
  @@index([categoryName])
  @@index([kind])
  @@index([isActive])
}

model RomaneioCatalogSyncState {
  id         String   @id
  sourceHash String
  syncedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RomaneioNotificationRecipient {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model AllocationReportRecipient {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model AllocationReportDelivery {
  id             String   @id @default(cuid())
  yearMonth      String   @unique
  recipientCount Int      @default(0)
  status         String   @default("SENT")
  error          String?
  sentAt         DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sentAt])
  @@index([status])
}

model ModuleRole {
  id        String         @id @default(uuid())
  userId    String
  module    AppModule
  role      ModuleRoleCode
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, module, role])
}

model DataRetentionRun {
  id                    String    @id @default(cuid())
  mode                  String    @default("APPLY")
  status                String    @default("RUNNING")
  deleteAbandonedDrafts Boolean   @default(false)
  cutoffs               Json?
  summary               Json?
  error                 String?
  startedAt             DateTime  @default(now())
  finishedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status, startedAt])
  @@index([startedAt])
}

model SatisfactionSurvey {
  id                 String    @id @default(cuid())
  projectId          String
  tokenHash          String    @unique
  tokenEncrypted     String
  tokenIv            String
  tokenAuthTag       String
  emailTo            String
  expiresAt          DateTime
  respondedAt        DateTime?
  sentAt             DateTime  @default(now())
  lastReminderAt     DateTime?
  reminderClaimedAt  DateTime?
  reminderOptOutAt   DateTime?
  reminderCount      Int       @default(0)
  expirationNotifiedAt DateTime?
  responses          Json?
  questions          Json?
  followUpStatus     String?
  followUpNotes      String?
  followUpUpdatedAt  DateTime?
  submittedIp        String?
  submittedUserAgent String?
  privacyNoticeAcceptedAt DateTime?
  privacyNoticeVersion String?
  sentByUserId       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sentBy             User?     @relation(fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([expiresAt, respondedAt, reminderOptOutAt])
  @@index([expirationNotifiedAt, expiresAt])
  @@index([respondedAt])
  @@index([sentAt])
}

model SatisfactionSurveyQuestion {
  id        String   @id @default(cuid())
  label     String
  type      String
  options   Json?
  required  Boolean  @default(true)
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model EmailChangeToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

model ReportDraft {
  id             String   @id @default(cuid())
  userId         String
  projectId      String?
  title          String?
  reportDate     String?
  payload        Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}

model UserSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model DataSubjectRequest {
  id              String                   @id @default(cuid())
  protocol        String                   @unique
  type            DataSubjectRequestType
  status          DataSubjectRequestStatus @default(OPEN)
  name            String
  email           String
  identifier      String?
  details         String
  source          String                   @default("PUBLIC_FORM")
  requesterUserId String?
  ipAddress       String?
  userAgent       String?
  responseNotes   String?
  responseEmailStatus String?
  responseEmailSentAt DateTime?
  responseEmailError String?
  identityVerifiedAt DateTime?
  identityVerifiedByUserId String?
  identityVerificationEvidence String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  completedAt     DateTime?
  completedByUserId String?
  completionNotes String?
  requesterUser   User?                    @relation("DataSubjectRequestUser", fields: [requesterUserId], references: [id], onDelete: SetNull)
  completedByUser User?                    @relation("DataSubjectRequestCompletedByUser", fields: [completedByUserId], references: [id], onDelete: SetNull)
  identityVerifiedByUser User?             @relation("DataSubjectRequestIdentityVerifiedByUser", fields: [identityVerifiedByUserId], references: [id], onDelete: SetNull)
  responseAttempts DataSubjectRequestResponseAttempt[]

  @@index([email])
  @@index([requesterUserId])
  @@index([completedByUserId])
  @@index([identityVerifiedByUserId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model DataSubjectRequestResponseAttempt {
  id              String             @id @default(cuid())
  requestId       String
  idempotencyKey  String             @unique
  message         String
  responseKind    String             @default("SUBSTANTIVE")
  resolved        Boolean            @default(false)
  status          String             @default("PENDING")
  emailTo         String
  emailSubject    String?
  providerMessageId String?
  error           String?
  sentAt          DateTime?
  createdByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  request         DataSubjectRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdByUser   User?              @relation("DataSubjectRequestResponseAttemptUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([createdByUserId])
  @@index([status])
}

model ReportAttachment {
  id              String        @id @default(cuid())
  reportId        String?
  reportServiceId String?
  label           String
  fileName        String
  mimeType        String
  storagePath     String
  createdAt       DateTime      @default(now())
  report          Report?       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportService   ReportService? @relation(fields: [reportServiceId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([reportServiceId])
  @@index([storagePath])
}
